# Bot Discord
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here (optionnel - pour deploy slash commands en dev)

# Salons
RECAP_CHANNEL_ID=
REMINDER_CHANNEL_ID=
UPDATE_CHANNEL_ID=
STATS_CHANNEL_ID=
GCHANNEL_ID=

# Rôles de niveau (optionnel — le bot les crée si absents)
ROLE_ROOKIE_ID=
ROLE_VETERAN_ID=
ROLE_LEGEND_ID=

# Serveur
PORT=3000

# Environnement
NODE_ENV=production
