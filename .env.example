# BUG FIX: l'original contenait de vrais tokens/IDs Discord — remplacés par des placeholders.
# Ne jamais commit de vraies credentials dans .env.example

# Bot Discord (obligatoire)
TOKEN=VOTRE_BOT_TOKEN_ICI
CLIENT_ID=VOTRE_CLIENT_ID_ICI
GUILD_ID=VOTRE_GUILD_ID_ICI  # optionnel: déploiement instantané sur un serveur

# MongoDB Atlas (obligatoire)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nexus?retryWrites=true&w=majority

# Salons Discord (optionnel, le bot sera silencieux sans eux)
RECAP_CHANNEL_ID=
REMINDER_CHANNEL_ID=
UPDATE_CHANNEL_ID=
STATS_CHANNEL_ID=
GCHANNEL_ID=

# Rôles de niveau (optionnel)
ROLE_ROOKIE_ID=
ROLE_VETERAN_ID=
ROLE_LEGEND_ID=

# Serveur
PORT=3000

# Environnement
NODE_ENV=development
